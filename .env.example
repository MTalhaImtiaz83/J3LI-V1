# J3LI Environment Configuration
# Copy to .env and fill in values

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=j3li_local_dev

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# LLM Provider (ollama | anthropic | openai | gemini)
J3LI_LLM_PROVIDER=ollama
J3LI_LLM_MODEL=llama3

# Embeddings
J3LI_EMBEDDING_PROVIDER=local
J3LI_EMBEDDING_MODEL=intfloat/multilingual-e5-large
